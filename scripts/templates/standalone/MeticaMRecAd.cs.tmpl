using UnityEngine;
using Metica;
using Metica.Ads;

namespace Metica.AbTest
{

public class MeticaMRecAd : MonoBehaviour
{
    private string _adUnitId;
    private bool _initialized = false;
    private bool _isShowing = false;

    // Initialize MUST be called from inside MeticaAdService's OnInitialized
    // callback — not before MeticaSdk.Initialize has fired its callback.
    public void Initialize(string adUnitId)
    {
        if (_initialized) return;
        _initialized = true;
        _adUnitId = adUnitId;

        MeticaAdsCallbacks.Mrec.OnAdLoadSuccess += OnLoadSuccess;
        MeticaAdsCallbacks.Mrec.OnAdLoadFailed  += OnLoadFailed;
        MeticaAdsCallbacks.Mrec.OnAdClicked     += OnClicked;
        MeticaAdsCallbacks.Mrec.OnAdRevenuePaid += OnRevenuePaid;
    }

    // Create the MRec. When placementTag is provided, attaches it via
    // SetMrecPlacement before Load — revenue postbacks are tagged by placement
    // and the analytics side loses that dimension if SetMrecPlacement is skipped.
    public void Create(MeticaAdViewPosition position = MeticaAdViewPosition.Centered,
                       string placementTag = null)
    {
        MeticaSdk.Ads.CreateMrec(_adUnitId, new MeticaAdViewConfiguration(position));
        if (!string.IsNullOrEmpty(placementTag))
            MeticaSdk.Ads.SetMrecPlacement(_adUnitId, placementTag);
    }

    public void Load()    => MeticaSdk.Ads.LoadMrec(_adUnitId);
    public void Show()    { MeticaSdk.Ads.ShowMrec(_adUnitId);    _isShowing = true; }
    public void Hide()    { MeticaSdk.Ads.HideMrec(_adUnitId);    _isShowing = false; }
    public void Destroy() { MeticaSdk.Ads.DestroyMrec(_adUnitId); _isShowing = false; }

    // Pause auto-refresh + hide while backgrounded; resume on foreground.
    // Only acts when the MRec was already showing — silent no-op otherwise.
    private void OnApplicationFocus(bool hasFocus)
    {
        if (!_isShowing) return;
        if (hasFocus)
        {
            MeticaSdk.Ads.StartMrecAutoRefresh(_adUnitId);
            MeticaSdk.Ads.ShowMrec(_adUnitId);
        }
        else
        {
            MeticaSdk.Ads.StopMrecAutoRefresh(_adUnitId);
            MeticaSdk.Ads.HideMrec(_adUnitId);
        }
    }

    // --- Named handlers (extend with analytics / UI hooks as needed) ---------

    private void OnLoadSuccess(MeticaAd ad)        { Debug.Log($"[Metica] MRec loaded: {ad.adUnitId}"); }
    // Per the docs example: MRec load-failure just logs. No app-side retry —
    // MeticaSDK's MRec pipeline handles refresh internally.
    private void OnLoadFailed(MeticaAdError error) { Debug.LogError($"[Metica] MRec load failed: {error.message}"); }
    private void OnClicked(MeticaAd ad)            { Debug.Log($"[Metica] MRec clicked: {ad.adUnitId}"); }
    private void OnRevenuePaid(MeticaAd ad)
    {
        Debug.Log($"[Metica] MRec revenue paid - AdUnit: {ad.adUnitId}, Revenue: {ad.revenue}, Network: {ad.networkName}, Placement: {ad.placementTag}");
    }
}

} // namespace Metica.AbTest
