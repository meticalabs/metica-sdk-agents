using System.Collections;
using UnityEngine;
using Metica;
using Metica.Ads;

namespace Metica.AbTest
{

public class MeticaMRecAd
{
    private readonly string _adUnitId;
    private readonly MonoBehaviour _runner;
    // Exponential backoff on load failure: 1s → 2s → 4s … capped at 64s.
    // Resets to 1s after a successful load.
    private const float _retryDelayMin = 1f;
    private const float _retryDelayMax = 64f;
    private float _retryDelay = _retryDelayMin;

    public MeticaMRecAd(string adUnitId, MonoBehaviour runner = null)
    {
        _adUnitId = adUnitId;
        _runner = runner;
        MeticaAdsCallbacks.Mrec.OnAdLoadSuccess += OnLoadSuccess;
        MeticaAdsCallbacks.Mrec.OnAdLoadFailed  += OnLoadFailed;
        MeticaAdsCallbacks.Mrec.OnAdClicked     += OnClicked;
        MeticaAdsCallbacks.Mrec.OnAdRevenuePaid += OnRevenuePaid;
    }

    public void Create(MeticaAdViewPosition position = MeticaAdViewPosition.Centered)
    {
        MeticaSdk.Ads.CreateMrec(_adUnitId, new MeticaAdViewConfiguration(position));
    }

    public void Load()    => MeticaSdk.Ads.LoadMrec(_adUnitId);
    public void Show()    => MeticaSdk.Ads.ShowMrec(_adUnitId);
    public void Hide()    => MeticaSdk.Ads.HideMrec(_adUnitId);
    public void Destroy() => MeticaSdk.Ads.DestroyMrec(_adUnitId);

    // --- Named handlers (extend with analytics / UI hooks as needed) ---------

    private void OnLoadSuccess(MeticaAd ad)
    {
        Debug.Log("[Metica] MRec loaded");
        _retryDelay = _retryDelayMin;
    }

    private void OnLoadFailed(MeticaAdError err)
    {
        Debug.LogWarning($"[Metica] MRec load failed; retry in {_retryDelay:F1}s");
        if (_runner != null) _runner.StartCoroutine(RetryAfter(_retryDelay));
        _retryDelay = Mathf.Min(_retryDelay * 2f, _retryDelayMax);
    }

    private void OnClicked(MeticaAd ad)       { Debug.Log("[Metica] MRec clicked"); }
    private void OnRevenuePaid(MeticaAd ad)   { Debug.Log("[Metica] MRec revenue"); }

    private IEnumerator RetryAfter(float delay)
    {
        yield return new WaitForSeconds(delay);
        Load();
    }
}

} // namespace Metica.AbTest
