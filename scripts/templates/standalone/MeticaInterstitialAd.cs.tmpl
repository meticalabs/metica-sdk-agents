// Generated by metica-sdk-agents (standalone codegen: fresh / straight-swap).
// Per-format object: owns the interstitial unit, its callbacks, and the
// canonical show → hidden → reload loop. Constructed and driven by MeticaAdService.
//
// MonoBehaviour so it can host the docs' Invoke-based retry (mirrors the
// docs.metica.com Unity SDK Ad Implementation example for Interstitial verbatim).
// The orchestrator MeticaAdService AddComponent's this onto its host GameObject
// and calls Initialize(adUnitId).
using UnityEngine;
using Metica;
using Metica.Ads;

namespace Metica.AbTest
{

public class MeticaInterstitialAd : MonoBehaviour
{
    private string _adUnitId;
    private int _retryAttempt = 0;
    private bool _initialized = false;

    public void Initialize(string adUnitId)
    {
        // Initialize MUST be called from inside MeticaAdService's OnInitialized
        // callback — not before MeticaSdk.Initialize has fired its callback.
        // Subscribing to MeticaAdsCallbacks.Interstitial.* before the SDK is up
        // means events fired during init will be missed.
        if (_initialized) return;
        _initialized = true;
        _adUnitId = adUnitId;

        MeticaAdsCallbacks.Interstitial.OnAdLoadSuccess += OnLoadSuccess;
        MeticaAdsCallbacks.Interstitial.OnAdLoadFailed  += OnLoadFailed;
        MeticaAdsCallbacks.Interstitial.OnAdShowSuccess += OnShowSuccess;
        MeticaAdsCallbacks.Interstitial.OnAdShowFailed  += OnShowFailed;
        MeticaAdsCallbacks.Interstitial.OnAdHidden      += OnHidden;
        MeticaAdsCallbacks.Interstitial.OnAdClicked     += OnClicked;
        MeticaAdsCallbacks.Interstitial.OnAdRevenuePaid += OnRevenuePaid;

        Load();
    }

    private void Load()
    {
        MeticaSdk.Ads.LoadInterstitial(_adUnitId);
    }

    public bool IsReady() => MeticaSdk.Ads.IsInterstitialReady(_adUnitId);

    public void Show(string placement = null, string customData = null)
    {
        // Guard: never show a not-yet-loaded ad.
        if (MeticaSdk.Ads.IsInterstitialReady(_adUnitId))
            MeticaSdk.Ads.ShowInterstitial(_adUnitId, placement, customData);
    }

    // --- Named handlers (extend with analytics / UI hooks as needed) ---------

    private void OnLoadSuccess(MeticaAd ad)
    {
        _retryAttempt = 0;
        Debug.Log($"[Metica] interstitial loaded: {ad.adUnitId}");
    }

    // Retry on load failure — docs.metica.com Unity SDK example, verbatim.
    private void OnLoadFailed(MeticaAdError error)
    {
        _retryAttempt++;
        double delay = System.Math.Pow(2, System.Math.Min(6, _retryAttempt));
        Debug.LogWarning($"[Metica] interstitial load failed: {error.message}, retrying in {delay}s");
        Invoke(nameof(Load), (float)delay);
    }

    private void OnShowSuccess(MeticaAd ad)   { Debug.Log("[Metica] interstitial displayed"); }
    private void OnShowFailed(MeticaAd ad, MeticaAdError error)
    {
        Debug.LogError($"[Metica] interstitial show failed: {error.message}");
        // Show-failed fires when a loaded ad fails to display (expiry / network blip).
        // OnAdHidden does NOT fire on show-failure, so the canonical reload-on-hidden
        // loop would stall without this. Reload to keep the loop alive.
        Load();
    }
    // Auto-reload: load the next interstitial as soon as the current one is dismissed.
    private void OnHidden(MeticaAd ad)        { Load(); }
    private void OnClicked(MeticaAd ad)       { Debug.Log("[Metica] interstitial clicked"); }
    private void OnRevenuePaid(MeticaAd ad)
    {
        Debug.Log($"[Metica] interstitial revenue paid - AdUnit: {ad.adUnitId}, Revenue: {ad.revenue}, Network: {ad.networkName}, Placement: {ad.placementTag}");
    }
}

} // namespace Metica.AbTest
