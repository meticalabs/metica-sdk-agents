using System.Collections;
using UnityEngine;
using Metica;
using Metica.Ads;

namespace Metica.AbTest
{

public class MeticaRewardedAd
{
    private readonly string _adUnitId;
    private readonly MonoBehaviour _runner;
    // Exponential backoff on load failure: 1s → 2s → 4s → 8s … capped at 64s.
    // Resets to 1s after a successful load.
    private const float _retryDelayMin = 1f;
    private const float _retryDelayMax = 64f;
    private float _retryDelay = _retryDelayMin;

    public MeticaRewardedAd(string adUnitId, MonoBehaviour runner = null)
    {
        _adUnitId = adUnitId;
        _runner = runner;
        MeticaAdsCallbacks.Rewarded.OnAdLoadSuccess += OnLoadSuccess;
        MeticaAdsCallbacks.Rewarded.OnAdLoadFailed  += OnLoadFailed;
        MeticaAdsCallbacks.Rewarded.OnAdShowSuccess += OnShowSuccess;
        MeticaAdsCallbacks.Rewarded.OnAdShowFailed  += OnShowFailed;
        MeticaAdsCallbacks.Rewarded.OnAdHidden      += OnHidden;
        MeticaAdsCallbacks.Rewarded.OnAdClicked     += OnClicked;
        MeticaAdsCallbacks.Rewarded.OnAdRewarded    += OnRewarded;
        MeticaAdsCallbacks.Rewarded.OnAdRevenuePaid += OnRevenuePaid;
    }

    // Load immediately after init success, and again on every hidden (below).
    public void Load() => MeticaSdk.Ads.LoadRewarded(_adUnitId);

    public bool IsReady() => MeticaSdk.Ads.IsRewardedReady(_adUnitId);

    public void Show(string placement = null, string customData = null)
    {
        // Guard: never show a not-yet-loaded ad.
        if (MeticaSdk.Ads.IsRewardedReady(_adUnitId))
            MeticaSdk.Ads.ShowRewarded(_adUnitId, placement, customData);
    }

    // --- Named handlers (extend with analytics / UI hooks as needed) ---------

    private void OnLoadSuccess(MeticaAd ad)
    {
        Debug.Log("[Metica] rewarded loaded");
        _retryDelay = _retryDelayMin;
    }

    private void OnLoadFailed(MeticaAdError err)
    {
        Debug.LogWarning($"[Metica] rewarded load failed; retry in {_retryDelay:F1}s");
        if (_runner != null) _runner.StartCoroutine(RetryAfter(_retryDelay));
        _retryDelay = Mathf.Min(_retryDelay * 2f, _retryDelayMax);
    }

    private void OnShowSuccess(MeticaAd ad)   { Debug.Log("[Metica] rewarded displayed"); }
    private void OnShowFailed(MeticaAd ad, MeticaAdError err)
    {
        Debug.LogError($"[Metica] rewarded show failed: {err.message}");
        // Show-failed fires when a loaded ad fails to display (expiry / network blip).
        // OnAdHidden does NOT fire on show-failure, so the canonical reload-on-hidden
        // loop would stall without this. Reload to keep the loop alive.
        Load();
    }
    // Auto-reload: load the next rewarded as soon as the current one is dismissed.
    private void OnHidden(MeticaAd ad)        { Load(); }
    private void OnClicked(MeticaAd ad)       { Debug.Log("[Metica] rewarded clicked"); }
    // Reward granted — game should credit the user here (currency, unlock, etc.).
    private void OnRewarded(MeticaAd ad)      { Debug.Log("[Metica] rewarded reward granted"); }
    private void OnRevenuePaid(MeticaAd ad)   { Debug.Log("[Metica] rewarded revenue"); }

    private IEnumerator RetryAfter(float delay)
    {
        yield return new WaitForSeconds(delay);
        Load();
    }
}

} // namespace Metica.AbTest
