// Generated by metica-sdk-agents (standalone codegen: fresh / straight-swap).
// Per-format object: banners are persistent, so the lifecycle is
// create → load → show → hide → destroy. Mirrors the canonical demo at
// https://github.com/meticalabs/metica-unity/blob/develop/Assets/Scripts/HomeScreen.cs
// — including: optional placement tag attached at Create, _isShowing state
// flag, and OnApplicationFocus pause/resume that stops/restarts auto-refresh
// so the SDK doesn't burn impressions while the app is backgrounded.
// Driven by MeticaAdService.
using UnityEngine;
using Metica;
using Metica.Ads;

namespace Metica.AbTest
{

public class MeticaBannerAd : MonoBehaviour
{
    private string _adUnitId;
    private bool _initialized = false;
    private bool _isShowing = false;

    // Initialize MUST be called from inside MeticaAdService's OnInitialized
    // callback — not before MeticaSdk.Initialize has fired its callback.
    // Subscribing to MeticaAdsCallbacks.Banner.* before the SDK is up means
    // events fired during init will be missed.
    public void Initialize(string adUnitId)
    {
        if (_initialized) return;
        _initialized = true;
        _adUnitId = adUnitId;

        MeticaAdsCallbacks.Banner.OnAdLoadSuccess += OnLoadSuccess;
        MeticaAdsCallbacks.Banner.OnAdLoadFailed  += OnLoadFailed;
        MeticaAdsCallbacks.Banner.OnAdClicked     += OnClicked;
        MeticaAdsCallbacks.Banner.OnAdRevenuePaid += OnRevenuePaid;
    }

    // Create the banner. When placementTag is provided, attaches it via
    // SetBannerPlacement before Load — revenue postbacks are tagged by placement
    // and the analytics side loses that dimension if SetBannerPlacement is skipped.
    public void Create(MeticaAdViewPosition position = MeticaAdViewPosition.BottomCenter,
                       string placementTag = null)
    {
        MeticaSdk.Ads.CreateBanner(_adUnitId, new MeticaAdViewConfiguration(position));
        if (!string.IsNullOrEmpty(placementTag))
            MeticaSdk.Ads.SetBannerPlacement(_adUnitId, placementTag);
    }

    public void Load()    => MeticaSdk.Ads.LoadBanner(_adUnitId);
    public void Show()    { MeticaSdk.Ads.ShowBanner(_adUnitId);    _isShowing = true; }
    public void Hide()    { MeticaSdk.Ads.HideBanner(_adUnitId);    _isShowing = false; }
    public void Destroy() { MeticaSdk.Ads.DestroyBanner(_adUnitId); _isShowing = false; }

    // Pause auto-refresh + hide while backgrounded; resume on foreground.
    // Only acts when the banner was already showing — silent no-op otherwise.
    private void OnApplicationFocus(bool hasFocus)
    {
        if (!_isShowing) return;
        if (hasFocus)
        {
            MeticaSdk.Ads.StartBannerAutoRefresh(_adUnitId);
            MeticaSdk.Ads.ShowBanner(_adUnitId);
        }
        else
        {
            MeticaSdk.Ads.StopBannerAutoRefresh(_adUnitId);
            MeticaSdk.Ads.HideBanner(_adUnitId);
        }
    }

    // --- Named handlers (extend with analytics / UI hooks as needed) ---------

    private void OnLoadSuccess(MeticaAd ad)        { Debug.Log($"[Metica] banner loaded: {ad.adUnitId}"); }
    // Per the docs example: banner load-failure just logs. No app-side retry —
    // MeticaSDK's banner pipeline handles refresh internally.
    private void OnLoadFailed(MeticaAdError error) { Debug.LogError($"[Metica] banner load failed: {error.message}"); }
    private void OnClicked(MeticaAd ad)            { Debug.Log($"[Metica] banner clicked: {ad.adUnitId}"); }
    private void OnRevenuePaid(MeticaAd ad)
    {
        Debug.Log($"[Metica] banner revenue paid - AdUnit: {ad.adUnitId}, Revenue: {ad.revenue}, Network: {ad.networkName}, Placement: {ad.placementTag}");
    }
}

} // namespace Metica.AbTest
