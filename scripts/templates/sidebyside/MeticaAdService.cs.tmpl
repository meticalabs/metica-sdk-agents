// Shared MeticaAd → IAdService data conversion (Metica-specific; kept out of the
// SDK-agnostic IAdService.cs so MaxAdService stays decoupled from MeticaSdk types).
internal static class MeticaAdConvert
{
    public static AdEventData Event(MeticaAd ad) => new AdEventData
    {
        AdUnitId    = ad.adUnitId,
        NetworkName = ad.networkName,
        Revenue     = ad.revenue ?? 0,
        AdFormat    = ad.adFormat,
        Placement   = ad.placementTag,
        LatencyMs   = ad.latency ?? 0,
        SdkSource   = "MeticaSdk"
    };

    public static AdErrorData Error(MeticaAdError err) => new AdErrorData
    {
        AdUnitId  = err.adUnitId,
        Message   = err.message,
        SdkSource = "MeticaSdk"
